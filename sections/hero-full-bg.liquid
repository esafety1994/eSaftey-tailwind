{% comment %}
  Section: Hero Full Background
  - Full-width background image
  - Section-level button text/url
  - Up to 2 blocks rendered as columns with gap-16
{% endcomment %}

<section id="hero-full-bg-{{ section.id }}" class="hero-full-bg relative w-full my-6">
  <div class="relative z-20 container mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 items-stretch">
      {% for block in section.blocks %}
        {% assign bg_image = block.settings.background_image %}
        <div
          class="block-content text-white relative overflow-hidden"
          style="min-height: 240px;"
        >
          {%- if bg_image != blank -%}
            <img
              src="{{ bg_image | image_url: width: 800 }}"
              srcset="{{ bg_image | image_url: width: 400 }} 400w, {{ bg_image | image_url: width: 800 }} 800w, {{ bg_image | image_url: width: 1200 }} 1200w"
              sizes="(max-width: 768px) 100vw, 50vw"
              alt="{{ bg_image.alt | escape }}"
              loading="eager"
              {% if forloop.first %}fetchpriority="high"{% endif %}
              width="{{ bg_image.width }}"
              height="{{ bg_image.height }}"
              class="absolute inset-0 w-full h-full object-cover"
            >
          {%- endif -%}
          <div class="relative p-8 h-full flex flex-col justify-center">
            {% if block.settings.button_text != blank %}
              <div class="text-center">
                <a
                  href="{{ block.settings.button_url }}"
                  class="inline-flex btn primary-button !rounded-4xl !normal-case"
                >
                  {{- block.settings.button_text -}}
                </a>
              </div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
      {% assign missing = 2 | minus: section.blocks.size %}
      {% for i in (1..missing) %}
        <div class="block-content text-white bg-gray-100 rounded-md" style="min-height:360px"></div>
      {% endfor %}
    </div>
  </div>

  {% schema %}
{
  "name": "Hero — Full Background",
  "settings": [],
  "blocks": [
    {
      "type": "column",
      "name": "Column",
      "settings": [
        { "type": "image_picker", "id": "background_image", "label": "Column background image" },
        { "type": "text", "id": "button_text", "label": "Button text" },
        { "type": "url", "id": "button_url", "label": "Button URL" }
      ]
    }
  ],
  "max_blocks": 2,
  "presets": [{ "name": "Hero — Full Background", "category": "Hero" }]
}
  {% endschema %}
</section>
