<section class="top-collections py-8">
  <div class="container mx-auto px-4">
    {% if section.settings.heading != blank %}
      <h3 class="text-2xl md:text-4xl font-semibold mb-6 text-center uppercase md:mb-12">
        {{ section.settings.heading }}
      </h3>
    {% endif %}

    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-6">
      {% for block in section.blocks %}

        {% assign product = all_products[block.settings.product] %}
        {% assign collection = collections[block.settings.collection] %}

        {% if product %}
          {% assign link_url = product.url %}
          {% assign title = product.title %}
          {% assign image = product.featured_image %}
        {% elsif collection %}
          {% assign link_url = collection.url %}
          {% assign title = collection.title %}
          {% assign image = collection.image %}
        {% else %}
          {% continue %}
        {% endif %}

        <a href="{{ link_url }}" class="group block">
          {% if image %}
            {% render 'responsive-image',
              image: image,
              alt: title,
              image_class: 'w-auto h-32 md:h-22 lg:h-32 object-cover transition-transform group-hover:scale-105 rounded-full mx-auto'
            %}
          {% else %}
            <div class="flex items-center justify-center h-32 rounded-full bg-gray-100 text-gray-500 mx-auto">
              No image
            </div>
          {% endif %}

          <p class="mt-2 text-center text-sm md:text-base">
            {{ title }}
          </p>
        </a>

      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Top Collections",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Top Collections"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Collection or Product",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection (optional)"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Product (overrides collection)"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Top Collections",
      "category": "Collections"
    }
  ]
}
{% endschema %}
``