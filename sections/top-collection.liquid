<section class="top-collections py-8">
  <div class="container mx-auto px-4">
    {% if section.settings.heading != blank %}
      <h3 class="text-2xl md:text-4xl font-semibold mb-6 text-center uppercase md:mb-12">
        {{ section.settings.heading }}
      </h3>
    {% endif %}

    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-6">

      {% for block in section.blocks %}
        {% case block.type %}

        {% when 'collection' %}
          {% assign coll = collections[block.settings.collection] %}
          {% if coll %}
            <a href="{{ coll.url }}" class="group block text-center">
              <div class="circle-bg">
                {% if block.settings.icon %}
                  {% render 'responsive-image',
                    image: block.settings.icon,
                    alt: coll.title,
                    image_class: 'circle-image transition-transform group-hover:scale-105'
                  %}
                {% elsif coll.image %}
                  {% render 'responsive-image',
                    image: coll.image,
                    alt: coll.title,
                    image_class: 'circle-image transition-transform group-hover:scale-105'
                  %}
                {% endif %}
              </div>
              <p class="mt-2 text-sm md:text-base">
                {{ coll.title }}
              </p>
            </a>
          {% endif %}

        {% when 'product' %}
          {% assign product = all_products[block.settings.product] %}
          {% if product %}
            <a href="{{ product.url }}" class="group block text-center">
              <div class="circle-bg">
                {% if block.settings.image %}
                  {% render 'responsive-image',
                    image: block.settings.image,
                    alt: product.title,
                    image_class: 'circle-image transition-transform group-hover:scale-105'
                  %}
                {% endif %}
              </div>
              <p class="mt-2 text-sm md:text-base">
                {{ product.title }}
              </p>
            </a>
          {% endif %}

        {% endcase %}
      {% endfor %}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Top Collections",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Top Collections"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon override (recommended)",
          "info": "Upload a transparent PNG or SVG icon to avoid backgrounds"
        }
      ]
    },
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product link"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image (icon)",
          "info": "Uploaded icon image (transparent PNG or SVG)"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Top Collections",
      "category": "Collections"
    }
  ]
}
{% endschema %}