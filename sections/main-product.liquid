{% comment %} Custom variant / custom field logic {% endcomment %}
<script>
  window.productVariants = {{ product.variants | json }};
  
  document.addEventListener('DOMContentLoaded', () => {
    const customField = document.querySelector('[data-custom-field]');
    if (!customField) return;

    const container = document.querySelector('[data-has-custom-variant]');
    const hasVariantGate = container?.dataset.hasCustomVariant === 'true';

    const inputs = customField.querySelectorAll('input, textarea, select');

    // Products WITHOUT custom variant → always show
    if (!hasVariantGate) {
      customField.style.display = '';
      inputs.forEach(el => {
        el.disabled = false;
      });
      return;
    }

    function toggleCustomFieldByVariantId() {
      const variantIdInput = document.querySelector('input[name="id"]');
      if (!variantIdInput || !window.productVariants) return;

      const variantId = Number(variantIdInput.value);
      const variant = window.productVariants.find(v => v.id === variantId);

      if (!variant) return;

      const isCustom = variant.title.toLowerCase().includes('custom');

      if (isCustom) {
        customField.style.display = '';
        inputs.forEach(el => {
          el.disabled = false;
          el.required = true;
        });
      } else {
        customField.style.display = 'none';
        inputs.forEach(el => {
          el.disabled = true;
          el.required = false;
          el.value = '';
        });
      }
    }

    // Run on load
    toggleCustomFieldByVariantId();

    // Watch variant changes (hidden input updates)
    document.addEventListener('change', event => {
      if (event.target.name === 'id') {
        toggleCustomFieldByVariantId();
      }
    });
  });
</script>