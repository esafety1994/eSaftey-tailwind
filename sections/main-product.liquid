{% comment %}
  main-product.liquid
  Two-column product page: left (info), right (image carousel with Glide.js)
{% endcomment %}

{% comment %} {% if customer %}
  B2B: {{ customer.b2b? }}
{% endif %} {% endcomment %}



<div class="container mx-auto px-4 pt-8 max-w-7xl" data-has-custom-variant="{% if product.tags contains 'requires-custom-variant' %}true{% else %}false{% endif %}">
  <div class="product-container grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
    <div>
      {% render 'product-media-gallery' %}
      <script
        src="https://widget.shopassistant-ai.com/preguide_ai.js"
        data-tenantid="tnt_VIostKRn5lTpaXD"
        data-app-type="pdp"
        defer
      ></script>
      <div class="mt-6 border-t border-grey">
        {% render 'product-faq-preview', product: product %}
      </div>
    </div>
    <!-- Product Info (Right) -->
    <div>
      <h1 class="text-3xl font-semibold mb-4">{{ product.title }}</h1>
      {% render 'product-tags', product: product %}
      {% render 'product-review', product: product, layout:"PDP" %}
      {% assign current_variant = product.selected_or_first_available_variant %}
      <div class="flex gap-4 items-center">
        <div id="product-sku">
          {% assign current_variant = product.selected_or_first_available_variant %}
          {% if current_variant and current_variant.sku %}
            <div class="text-sm text-gray-600 my-4">
              SKU: <span class="sku-value">{{ current_variant.sku }}</span>
            </div>
          {% endif %}
        </div>
        {% render 'product-stock-badge', product: product %}
      </div>
      <div id="product-price" class="mb-4 text-xl font-semibold">
        {% render 'product-price', product: product, show_compare_price: true, price_size: 20, show_ex_gst: true %}
      </div>

      <div class="my-6 border-gray-300 border-y-1 py-6">
        {% render 'product-features', product: product %}
      </div>

      {% render 'variant_picker' %}

      {% render 'product-fixing', product: product %}
      {% assign custom_block = section.blocks | where: 'type', 'custom_field' | first %}
      {% assign product_form_id = 'product-form-' | append: product.id %}
      {% comment %} {% if product.template_suffix == 'product-with-custom-field' and custom_block %} {% endcomment %}
      {% if custom_block %}
        {% render 'product-custom-field', block: custom_block, product: product, product_form_id: product_form_id %}
      {% endif %}

      {% render 'bulk-discount', product: product %}
      {% render 'backorder-text', product: product %}
      {% render 'act-button', product: product, showPlus: true %}
     
      {% render 'product-below-act-button', product: product %}
      {% if product.tags contains 'Bulky' %}
        {% render 'bulky-item-shipping-note' %}
      {% endif %}
      <div class="mt-6 border-t border-grey">
        {% render 'product-quotify-button', product: product %}
      </div>
      
      <script>
        window.productVariants = {{ product.variants | json }};
      </script>
    </div>
  </div>
</div>

{% comment %} Sticky product cart (fixed under header) {% endcomment %}
{% render 'sticky-product-cart', product: product %}
{% render 'shipping-calculator', product: product %}
{% comment %} {% render 'no-reviews-enhancer' %} — snippet missing, commented out to suppress Liquid error {% endcomment %}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "@id": "{{ shop.url }}{{ product.url }}",
  "name": {{ product.title | json }},
  "image": [
    {% if product.featured_image %}
      "{{ product.featured_image | image_url: width: 1200 }}"
    {% endif %}
  ],
  "description": {{ product.description | strip_html | strip_newlines | truncate: 160 | json }},
  "sku": {{ product.selected_or_first_available_variant.sku | json }},
  "brand": {
    "@type": "Brand",
    "name": {{ product.vendor | json }}
  },
  "offers": {
    "@type": "Offer",
    "url": "{{ shop.url }}{{ product.url }}",
    "priceCurrency": "{{ cart.currency.iso_code }}",
    "price": {{ product.selected_or_first_available_variant.price | divided_by: 100.0 | json }},
    "availability": "https://schema.org/{% if product.available %}InStock{% else %}OutOfStock{% endif %}"
  }
}
</script>

{% assign faq = product.metafields.custom.rich_text %}

{% if faq and faq != blank %}

  {% capture faq_html %}
    {{ faq | metafield_tag }}
  {% endcapture %}

  {% assign parts = faq_html | split: '<p>' %}
  {% assign has_faq = false %}

  {% capture faq_items %}
    {% assign first = true %}

    {% for part in parts %}
      
      {% if part contains '<strong>' %}
        
        {% assign question = part 
          | split: '<strong>' 
          | last 
          | split: '</strong>' 
          | first 
          | strip 
        %}

        {% assign next_index = forloop.index %}
        {% assign answer_part = parts[next_index] | strip %}

        {% assign answer = answer_part 
          | remove: '</p>' 
          | strip_html 
          | strip 
        %}

        {% if question != blank and answer != blank %}
          {% assign has_faq = true %}

          {% unless first %},{% endunless %}
          {
            "@type": "Question",
            "name": {{ question | json }},
            "acceptedAnswer": {
              "@type": "Answer",
              "text": {{ answer | json }}
            }
          }
          {% assign first = false %}
        {% endif %}

      {% endif %}

    {% endfor %}
  {% endcapture %}

  {% if has_faq %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {{ faq_items }}
    ]
  }
  </script>
  {% endif %}

{% endif %}
