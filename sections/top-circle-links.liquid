<section class="top-collections py-8">
  <div class="container mx-auto px-4">
    {% if section.settings.heading != blank %}
      <h3 class="text-2xl md:text-4xl font-semibold mb-6 text-center uppercase md:mb-12">
        {{ section.settings.heading }}
      </h3>
    {% endif %}

    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-6">
      {% for block in section.blocks %}
        <a
          href="{{ block.settings.link }}"
          class="group block"
          {% if block.settings.link == blank %}
            aria-disabled="true"
          {% endif %}
        >
          {% if block.settings.image %}
            {% render 'responsive-image',
              image: block.settings.image,
              alt: block.settings.label,
              image_class: 'w-auto h-32 md:h-22 lg:h-32 object-cover transition-transform group-hover:scale-105 rounded-full mx-auto',
            %}
          {% else %}
            <div class="flex items-center justify-center h-32 rounded-full bg-gray-100 text-gray-500 mx-auto">
              No image
            </div>
          {% endif %}

          {% if block.settings.label != blank %}
            <p class="mt-2 text-center text-sm md:text-base">
              {{ block.settings.label }}
            </p>
          {% endif %}
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Top circle links",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Top Links"
    }
  ],
  "blocks": [
    {
      "type": "link",
      "name": "Circle link",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (product, page, collection, etc)"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Top circle links",
      "category": "Custom"
    }
  ]
}
{% endschema %}