"streetAddress": "396 Victoria St",
"addressLocality": "Wetherill Park NSW",
"addressRegion": "NSW",
"postalCode": "2164",
"addressCountry": "AU"
},

"review": {
"@type": "Review",
"reviewRating": {
"@type": "Rating",
"ratingValue": 5,
"bestRating": 5
},
"author": {
"@type": "Person",
"name": "Matthew Ryan"
}
},

"geo": {
"@type": "GeoCoordinates",
"latitude": -33.8448213,
"longitude": 150.8830471
},
"openingHoursSpecification": [
