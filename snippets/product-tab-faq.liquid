{% comment %} Prefer the explicit `custom.rich_text` metafield and render with `rich_text` filter. Fallback to other keys if absent. {% endcomment %}
{% assign faq = product.metafields.custom.rich_text %}
{% if faq and faq != blank %}
  <div class="faq-section text-sm p-4 rounded">
    {{ faq | metafield_tag }}
  </div>
{% else %}
  <div class="text-sm text-gray-600 py-4">FAQ coming soon!</div>
{% endif %}
{% if faq and faq != blank and faq_schema_rendered != true %}

  {% capture faq_html %}
    {{ faq | metafield_tag }}
  {% endcapture %}

  {% assign clean_text = faq_html | strip_html %}
  {% assign lines = clean_text | split: '\n' %}

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {% assign first = true %}

      {% for line in lines %}
        {% assign current = line | strip %}

        {% if current != blank %}
          
          {% assign index = forloop.index0 | modulo: 2 %}

          {% if index == 0 %}
            {% assign question = current %}
          {% else %}
            {% assign answer = current %}

            {% if question != blank and answer != blank %}
              {% unless first %},{% endunless %}
              {
                "@type": "Question",
                "name": {{ question | json }},
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": {{ answer | json }}
                }
              }
              {% assign first = false %}
            {% endif %}

          {% endif %}

        {% endif %}
      {% endfor %}
    ]
  }
  </script>

  {% assign faq_schema_rendered = true %}

{% endif %}