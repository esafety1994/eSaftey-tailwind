<style>
  .datasheet-link {
    background-color: #ffd700;
    color: #000;
    padding: 8px 12px;
    border-radius: 6px;
    font-weight: 600;
    display: inline-flex;
    gap: 8px;
    align-items: center;
  }
</style>
<div class="datasheet-section py-4">
 
    {% if product.metafields.custom.product_tabs_product_data_sheet %}
      {% assign pdf_links = product.metafields.custom.product_tabs_product_data_sheet | split: '|' %}
      <ol class="flex flex-wrap gap-4 p-0 m-0 list-none">
        {% for pdf in pdf_links %}
          <li>
            <a class="datasheet-link" href="{{ pdf | strip }}" target="_blank">View Data Sheet (PDF)</a>
          </li>
        {% endfor %}
      </ol>
    {% else %}
      <p class="text-sm text-gray-600">Data Sheet coming soon!</p>
    {% endif %}

</div>
