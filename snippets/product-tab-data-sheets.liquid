<style>
  .datasheet-link {
    background-color: #ffd700;
    color: #000;
    padding: 8px 12px;
    border-radius: 6px;
    font-weight: 600;
    display: inline-flex;
    gap: 8px;
    align-items: center;
  }
</style>

<div class="datasheet-section py-4">
  {%- assign has_modular = false -%}
  {%- if product.tags contains 'Modular Handrails' -%}
    {%- assign has_modular = true -%}
  {%- endif -%}

  {%- assign metafield_raw = product.metafields.custom.product_tabs_product_data_sheet -%}
  {%- assign has_metafield = false -%}
  {%- if metafield_raw != blank -%}
    {%- assign has_metafield = true -%}
  {%- endif -%}

  {%- if has_modular or has_metafield -%}
    <ol class="flex flex-wrap gap-4 p-0 m-0 list-none">

      {%- if has_modular -%}
        <li>
          <a
            class="datasheet-link"
            href="https://cdn.shopify.com/s/files/1/0638/5175/7736/files/Cope_Modular_Brochure_eSafetySupplies2025.pdf"
            target="_blank"
            rel="noopener"
          >
            Download Brochure
          </a>
        </li>
      {%- endif -%}

      {%- if has_metafield -%}
        {%- assign pdf_links = metafield_raw | split: '|' -%}
        {%- for pdf in pdf_links -%}
          {%- assign pdf_url = pdf | strip -%}
          {%- if pdf_url != blank -%}
            <li>
              <a class="datasheet-link" href="{{ pdf_url }}" target="_blank" rel="noopener">
                View Data Sheet (PDF)
              </a>
            </li>
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}

    </ol>
  {%- else -%}
    <p class="text-sm text-gray-600">Data Sheet coming soon!</p>
  {%- endif -%}
</div>