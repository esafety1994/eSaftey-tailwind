<div class="mt-6 text-sm leading-tight text-gray-600 flex gap-2.5 lg:gap-8 flex-wrap">
  <a
    href="/pages/click-and-collect"
    target="_blank"
    class="border-gray-50 rounded-xl shadow-2xl py-4 px-2 grid gap-1 max-w-36 hover:scale-105 ease-in-out duration-200 transition-all"
  >
    <div class="flex gap-2 items-center">
      {% render 'icon-svg-store', class: 'size-10 text-yellow-500', stroke_width: 1.25 %}
      <div class="flex gap-2 flex-wrap">
        <p>Click & Collect</p>
      </div>
    </div>
    <div>
      <div class="flex gap-2 text-xs justify-center">
        <span class="underline text-gray-600">Find out more</span>
        {% render 'icon-svg-arrow-right-circle', class: 'size-5', stroke_width: 1.25 %}
      </div>
    </div>
  </a>

  <a
    href="#"
    onclick="triggerShippingEstimate(event)"
    class="border-gray-50 rounded-xl shadow-2xl py-4 px-2 grid gap-1 max-w-36 hover:scale-105 ease-in-out duration-200 transition-all"
  >
    <div class="flex gap-2 items-center ">
      {% render 'icon-svg-package', classes: 'size-10 text-yellow-500', stroke_width: 1.25 %}
      <div class="flex gap-2 flex-wrap">
        <p>Calculate Shipping</p>
      </div>
    </div>
    <div>
      <button
        class="underline text-gray-600 flex gap-2 text-xs justify-center w-full"
      >
        <div
          class="underline text-gray-600 flex gap-2 text-xs justify-center"
        >
          <span class="underline text-gray-600"> Get my Rates </span>
          {% render 'icon-svg-arrow-right-circle', class: 'size-5', stroke_width: 1.25 %}
        </div>
      </button>
    </div>
  </a>

  <a
    href="#"
    onclick="shippingAnchor(event)"
    class="relative group border-gray-50 rounded-xl shadow-2xl py-4 px-2 grid gap-1 max-w-36 hover:scale-105 ease-in-out duration-200 transition-all"
  >
    <div class="flex gap-2 items-center ">
      {% render 'icon-svg-truck', class: 'size-10 text-yellow-500', stroke_width: 1.25 %}
      <div class="flex gap-2 flex-wrap">
        <p>Delivery Times</p>
      </div>
    </div>
    <div>
      <div
        class="underline text-gray-600 flex gap-2 text-xs cursor-pointer justify-center"
      >
        Get my ETA
        {% render 'icon-svg-arrow-right-circle', class: 'size-5', stroke_width: 1.25 %}
      </div>
    </div>
    <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 hidden group-hover:block z-20 w-52 pointer-events-none">
      <div class="bg-gray-900 text-white text-xs rounded-lg px-3 py-2 text-center whitespace-nowrap">
        <div class="flex items-center gap-1.5 justify-center">
          <span class="leading-none">🚚</span>
          Estimated delivery <strong class="ml-1" id="pdp-eta-dates">–</strong>
        </div>
      </div>
      <div class="absolute top-full left-1/2 -translate-x-1/2 border-4 border-transparent border-t-gray-900"></div>
    </div>
  </a>
  <script>
    (function () {
      function addBizDays(d, n) {
        var r = new Date(d);
        for (var i = 0; i < n; ) {
          r.setDate(r.getDate() + 1);
          var dow = r.getDay();
          if (dow !== 0 && dow !== 6) i++;
        }
        return r;
      }
      var months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
      function fmt(d) { return d.getDate() + ' ' + months[d.getMonth()]; }
      var today = new Date();
      var el = document.getElementById('pdp-eta-dates');
      if (el) el.textContent = fmt(addBizDays(today, 1)) + ' – ' + fmt(addBizDays(today, 4));
    })();
  </script>

  <button
    type="button"
    data-price-beat-open
    class="border-gray-50 rounded-xl shadow-2xl py-4 px-2 grid gap-1 max-w-36 hover:scale-105 ease-in-out duration-200 transition-all text-left bg-transparent cursor-pointer"
  >
    <div class="flex gap-2 items-center">
      {% render 'icon-svg-percent-badge', class: 'size-10 text-red-500', stroke_width: 1.5 %}
      <div class="flex gap-2 flex-wrap">
        <p>Price Beat Guaranteed</p>
      </div>
    </div>
    <div>
      <div
        class="underline text-gray-600 flex gap-2 text-xs cursor-pointer justify-center"
      >
        Get Better Price
        {% render 'icon-svg-arrow-right-circle', class: 'size-5', stroke_width: 1.25 %}
      </div>
    </div>
  </button>
</div>

{% render 'price-beat-modal', product: product %}
