{% assign tiny_template_suffix = template.suffix | append: ".liquid" %}
{% assign tiny_page_name = template.name | replace: tiny_template_suffix, "" %}
{% assign _header = content_for_header %}

{% comment %} Customizery is only needed on product pages — strip it everywhere else {% endcomment %}
{% unless tiny_page_name == "product" %}
  {% assign _header = _header | remove: "https://d1liekpayvooaz.cloudfront.net/apps/customizery/customizery.js?shop=5c59e6.myshopify.com" %}
  {% assign _header = _header | remove: "https://d1liekpayvooaz.cloudfront.net/apps/customizery/customizery.js" %}
{% endunless %}

{% comment %} Rise.ai wallet widget is only relevant on cart and account pages {% endcomment %}
{% unless tiny_page_name == "cart" or tiny_page_name == "customers" %}
  {% assign _header = _header | remove_first: "strn.rise-ai.com" %}
{% endunless %}

{% comment %} Reviews.io widget only needed on product and collection pages {% endcomment %}
{% unless tiny_page_name == "product" or tiny_page_name == "collection" %}
  {% assign _header = _header | remove_first: "widget.reviews.io" %}
{% endunless %}

