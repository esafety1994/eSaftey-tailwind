<div class="ap-options__file-container grid gap-2 my-4 mt-6" data-design-upload>
  <span class="text-sm font-medium text-gray-700">
    Upload Your Logo Here
  </span>

  <label
    class="flex items-center justify-between
           w-full border border-gray-300 rounded-md
           px-3 py-2 text-sm text-gray-600
           cursor-pointer hover:bg-gray-50"
  >
    <span class="truncate" data-upload-filename>
      Choose file…
    </span>

    <svg
      class="w-5 h-5 text-gray-400"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M15.172 7l-6.586 6.586a2 2 0 002.828 2.828L18 9"
      />
    </svg>

    <!-- Visible file picker (UI only) -->
    <input
      type="file"
      accept=".jpg,.jpeg,.png,.pdf,.ai,.eps"
      class="hidden"
      data-ap-file
    >
  </label>

  <!-- THIS is what the theme/cart logic actually reads -->
  <input
    type="hidden"
    class="apo_value"
    name="properties[Design Reference]"
    field-name="Design Reference"
    value=""
  >

  <p class="text-xs text-gray-500">
    Only for custom type variants
  </p>
</div>

<script>
document.addEventListener('change', function (e) {
  const input = e.target;
  if (!input.matches('[data-ap-file]')) return;

  const file = input.files && input.files[0];
  if (!file) return;

  const wrapper = input.closest('.ap-options__file-container');
  if (!wrapper) return;

  const filenameSpan = wrapper.querySelector('[data-upload-filename]');
  const hiddenValue = wrapper.querySelector('.apo_value');

  if (filenameSpan) {
    filenameSpan.textContent = file.name;
    filenameSpan.classList.add('text-gray-900');
  }

  if (hiddenValue) {
    // Mirror Custom Signage behaviour: store a string reference
    hiddenValue.value = file.name;
  }
});
</script>