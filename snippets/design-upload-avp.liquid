<div class="ap-options__file-container grid gap-2 my-4 mt-6">
  <label class="text-sm font-medium text-gray-700">
    Upload Your Logo Here
  </label>

  <!-- AVP uploader hooks into this -->
  <input
    type="file"
    class="ap-file-input"
    data-ap-file
    accept=".jpg,.jpeg,.png,.pdf,.ai,.eps"
  >

  <!-- This gets populated by the uploader with a FILE URL -->
  <input
    type="hidden"
    class="apo_value"
    name="properties[Design Reference]"
    field-name="Design Reference"
    value=""
  >

  <p class="text-xs text-gray-500">
    Only for custom type variants
  </p>
</div>
