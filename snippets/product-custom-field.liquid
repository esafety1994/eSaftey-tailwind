{% liquid
  assign label_hidden = false
  assign field_type = block.settings.field_type
  assign field_options = block.settings.field_options
  assign field_name = block.settings.title
  assign field_placeholder = block.settings.field_placeholder
  assign field_required = block.settings.field_required
  assign show_at_checkout = block.settings.show_at_checkout
  assign field_help_text = block.settings.field_help_text

  if field_name == blank
    assign label_hidden = true
    assign field_name = 'Custom field ' | append: forloop.index
  endif
%}
<div
  class="m-product-custom-field py-4 flex flex-col gap-2 mb-4"
  data-custom-field
  style="display:none;"
>
  <label class="m-product-option--label{% if label_hidden %} m:hidden{% endif %}" for="{{ block.id }}">
    {{ field_name -}}
    {%- if field_required -%}
      <sup class="text-red-500">*</sup>
    {%- endif %}
  </label>
  {% unless show_at_checkout %}
    {% assign field_name = field_name | prepend: '_' %}
  {% endunless %}
  {% case field_type %}
    {% when 'text' %}
      <input
        type="text"
        id="{{ block.id }}"
        class="form-field form-field--input text-sm bg-gray-50 w-full box-border px-4 py-3 focus:outline-none"
        placeholder="{{ field_placeholder }}"
        name="properties[{{- field_name -}}]"
        {% if field_required %}
          required
        {% endif %}
        form="{{ product_form_id }}"
      >
    {% when 'textarea' %}
      <textarea
        id="{{ block.id }}"
        class="form-field form-field--input text-sm bg-gray-50 w-full box-border px-4 py-3 focus:outline-none"
        placeholder="{{ field_placeholder }}"
        name="properties[{{- field_name -}}]"
        {% if field_required %}
          required
        {% endif %}
        form="{{ product_form_id }}"
      ></textarea>
    {% when 'select' %}
      {% assign options = field_options | newline_to_br | split: '<br />' %}
      <select
        id="{{ block.id }}"
        class="form-field form-field--input bg-gray-50 w-full box-border px-4 py-3 focus:outline-none"
        name="properties[{{- field_name -}}]"
        {% if field_required %}
          required
        {% endif %}
        form="{{ product_form_id }}"
      >
        {% if field_placeholder != blank %}
          <option value="">{{ field_placeholder }}</option>
        {% endif %}
        {% for option in options %}
          <option value="{{ option }}" label="{{ option }}">{{ option }}</option>
        {% endfor %}
      </select>
    {% when 'file' %}
      <div class="file-upload-control flex items-center gap-3 flex-wrap">
        <input
          type="file"
          id="{{ block.id }}"
          class="sr-only"
          accept="image/png,image/jpeg,image/jpg"
          name="properties[{{- field_name -}}]"
          data-file-input
          {% if field_required %}
            required
          {% endif %}
          form="{{ product_form_id }}"
        >
        <label
          for="{{ block.id }}"
          class="file-upload-button inline-flex items-center gap-2 px-4 py-2 bg-black text-white text-sm font-medium rounded-md cursor-pointer hover:bg-gray-800 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4" aria-hidden="true">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="17 8 12 3 7 8"/>
            <line x1="12" y1="3" x2="12" y2="15"/>
          </svg>
          <span>Choose File</span>
        </label>
        <span class="file-upload-name text-sm text-gray-600" data-file-name>No file chosen</span>
      </div>
      <script>
        (function () {
          var input = document.getElementById('{{ block.id }}');
          if (!input || input.dataset.fileBound) return;
          input.dataset.fileBound = '1';
          input.addEventListener('change', function () {
            var display = input.closest('.m-product-custom-field')?.querySelector('[data-file-name]');
            if (!display) return;
            var file = input.files && input.files[0];
            display.textContent = file ? file.name : 'No file chosen';
          });
        })();
      </script>
    {% when 'cuts_calculator' %}
      <div class="cuts-calculator" data-cuts-calculator data-block-id="{{ block.id }}">
        <div class="cuts-calculator__header flex items-center gap-2 text-xs text-gray-500 font-medium mb-1 px-1">
          <span class="w-24">Length (m)</span>
          <span class="opacity-0 select-none" aria-hidden="true">×</span>
          <span class="w-20">Pieces</span>
        </div>
        <div class="cuts-calculator__rows space-y-2" data-cuts-rows>
          <div class="cuts-calculator__row flex items-center gap-2 flex-wrap" data-cuts-row>
            <input
              type="number"
              min="0.1"
              step="0.1"
              value="1"
              placeholder="e.g. 1.5"
              class="cuts-length bg-gray-50 px-3 py-2 w-24 text-sm border rounded focus:outline-none"
              inputmode="decimal"
              aria-label="Cut length in metres"
            >
            <span class="text-sm text-gray-500" aria-hidden="true">×</span>
            <input
              type="number"
              min="1"
              step="1"
              value="1"
              placeholder="Qty"
              class="cuts-qty bg-gray-50 px-3 py-2 w-20 text-sm border rounded focus:outline-none"
              inputmode="numeric"
              aria-label="Number of pieces"
            >
            <button
              type="button"
              class="cuts-remove text-xs text-red-600 underline ml-auto"
              data-remove-row
              aria-label="Remove this cut"
            >
              Remove
            </button>
          </div>
        </div>
        <button
          type="button"
          class="cuts-add-row mt-3 text-sm font-medium underline"
          data-add-row
        >
          + Add another cut
        </button>
        <div
          class="cuts-summary mt-3 p-3 bg-gray-50 border rounded text-sm"
          data-cuts-summary
        ></div>
        <div
          class="cuts-error mt-2 text-sm text-red-500 hidden"
          data-cuts-error
          role="alert"
        >
          Please enter at least one cut length and quantity before adding to cart.
        </div>
        <textarea
          id="{{ block.id }}"
          class="form-field cuts-summary-input sr-only"
          name="properties[{{- field_name -}}]"
          readonly
          tabindex="-1"
          aria-hidden="true"
          {% if field_required %}required{% endif %}
          form="{{ product_form_id }}"
        ></textarea>
      </div>
      <script>
        (function () {
          var root = document.querySelector('[data-cuts-calculator][data-block-id="{{ block.id }}"]');
          if (!root || root.dataset.cutsBound) return;
          root.dataset.cutsBound = '1';

          var rowsEl = root.querySelector('[data-cuts-rows]');
          var addBtn = root.querySelector('[data-add-row]');
          var summaryEl = root.querySelector('[data-cuts-summary]');
          var errorEl = root.querySelector('[data-cuts-error]');
          var hidden = root.querySelector('.cuts-summary-input');

          function escapeHtml(s) {
            return String(s).replace(/[&<>"']/g, function (c) {
              return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
            });
          }

          function rowTemplate() {
            var row = document.createElement('div');
            row.className = 'cuts-calculator__row flex items-center gap-2 flex-wrap';
            row.setAttribute('data-cuts-row', '');
            row.innerHTML =
              '<input type="number" min="0.1" step="0.1" value="1" placeholder="e.g. 1.5" class="cuts-length bg-gray-50 px-3 py-2 w-24 text-sm border rounded focus:outline-none" inputmode="decimal" aria-label="Cut length in metres">' +
              '<span class="text-sm text-gray-500" aria-hidden="true">×</span>' +
              '<input type="number" min="1" step="1" value="1" placeholder="Qty" class="cuts-qty bg-gray-50 px-3 py-2 w-20 text-sm border rounded focus:outline-none" inputmode="numeric" aria-label="Number of pieces">' +
              '<button type="button" class="cuts-remove text-xs text-red-600 underline ml-auto" data-remove-row aria-label="Remove this cut">Remove</button>';
            return row;
          }

          function getQuantityInput() {
            return (
              document.querySelector('#product-act-button input[name="quantity"]') ||
              document.querySelector('form[action*="/cart/add"] input[name="quantity"]') ||
              document.querySelector('input[name="quantity"]')
            );
          }

          function lockQuantitySelector(qtyEl) {
            if (!qtyEl) return;
            qtyEl.setAttribute('readonly', 'readonly');
            var qtyContainer = qtyEl.closest('.qty-selector');
            if (qtyContainer && !qtyContainer.dataset.cutsLocked) {
              qtyContainer.dataset.cutsLocked = '1';
              qtyContainer.querySelectorAll('button').forEach(function (b) {
                b.style.opacity = '0.35';
                b.style.pointerEvents = 'none';
              });
              qtyContainer.title = 'Quantity is set automatically from your cuts above.';
            }
          }

          function recompute() {
            var rows = root.querySelectorAll('[data-cuts-row]');
            var total = 0;
            var lines = [];
            rows.forEach(function (row) {
              var lengthInput = row.querySelector('.cuts-length');
              var qtyInput = row.querySelector('.cuts-qty');
              var len = parseFloat(lengthInput && lengthInput.value);
              var qty = parseInt(qtyInput && qtyInput.value, 10);
              if (!isFinite(len) || len <= 0) len = 0;
              if (!isFinite(qty) || qty <= 0) qty = 0;
              if (len > 0 && qty > 0) {
                total += len * qty;
                // Format: "1.5m x 4 pieces"
                lines.push(len + 'm x ' + qty + ' pieces');
              }
            });
            total = Math.round(total * 100) / 100;
            var billable = total > 0 ? Math.ceil(total) : 0;

            // Build the summary block + the line item property value from the
            // same set of lines so the on-page summary and the cart property
            // share the exact same format.
            var totalLine = '';
            if (lines.length > 0) {
              totalLine = 'Total length = ' + total + 'm';
              if (billable > total) {
                totalLine += ' (billed for ' + billable + 'm)';
              }
            }

            if (summaryEl) {
              if (lines.length === 0) {
                summaryEl.innerHTML = '<div class="text-gray-500">Enter cut sizes above to see your total.</div>';
              } else {
                var rowHtml = lines.map(function (line) {
                  return '<div>' + escapeHtml(line) + '</div>';
                }).join('');
                summaryEl.innerHTML =
                  rowHtml + '<div class="font-semibold mt-2">' + escapeHtml(totalLine) + '</div>';
              }
            }

            if (hidden) {
              if (lines.length === 0) {
                hidden.value = '';
              } else {
                hidden.value = lines.concat([totalLine]).join('\n');
              }
            }

            // Clear any inline error whenever the user enters a valid cut
            if (errorEl && lines.length > 0) {
              errorEl.classList.add('hidden');
            }

            var qtyEl = getQuantityInput();
            if (qtyEl) {
              qtyEl.value = billable > 0 ? billable : 1;
              lockQuantitySelector(qtyEl);
            }
          }

          rowsEl.addEventListener('input', function (e) {
            if (e.target.matches('.cuts-length, .cuts-qty')) recompute();
          });

          rowsEl.addEventListener('click', function (e) {
            var removeBtn = e.target.closest('[data-remove-row]');
            if (!removeBtn) return;
            var row = removeBtn.closest('[data-cuts-row]');
            var allRows = rowsEl.querySelectorAll('[data-cuts-row]');
            if (allRows.length > 1) {
              row.remove();
            } else {
              var lengthInput = row.querySelector('.cuts-length');
              var qtyInput = row.querySelector('.cuts-qty');
              if (lengthInput) lengthInput.value = '';
              if (qtyInput) qtyInput.value = '';
            }
            recompute();
          });

          addBtn.addEventListener('click', function () {
            rowsEl.appendChild(rowTemplate());
            recompute();
          });

          // Block Add to Cart if no valid cut lines entered. Capture phase so
          // we run BEFORE the regular cart-actions submit handler — that way
          // an empty cuts field stops the cart-add before AJAX fires.
          var cartForm = document.querySelector('#product-act-button form, form[action*="/cart/add"]');
          if (cartForm && !cartForm.dataset.cutsBound) {
            cartForm.dataset.cutsBound = '1';
            cartForm.addEventListener('submit', function (e) {
              // Re-read latest state in case rows were just edited
              var currentRows = root.querySelectorAll('[data-cuts-row]');
              var hasValidCut = false;
              currentRows.forEach(function (r) {
                var l = parseFloat(r.querySelector('.cuts-length') && r.querySelector('.cuts-length').value);
                var q = parseInt(r.querySelector('.cuts-qty') && r.querySelector('.cuts-qty').value, 10);
                if (isFinite(l) && l > 0 && isFinite(q) && q > 0) hasValidCut = true;
              });
              if (!hasValidCut) {
                e.preventDefault();
                e.stopPropagation();
                e.stopImmediatePropagation && e.stopImmediatePropagation();
                if (errorEl) {
                  errorEl.classList.remove('hidden');
                  errorEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
                }
                return false;
              }
            }, true);
          }

          recompute();
        })();
      </script>
  {% endcase %}
  {% if field_help_text != blank %}
    <p class="text-xs text-gray-500 mt-1">{{ field_help_text }}</p>
  {% endif %}
</div>
