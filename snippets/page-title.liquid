<div class="container mx-auto py-12 max-w-7xl text-center">
<h1 class="font-semibold text-4xl text-center">
  {{ title }}
  {% if template contains 'blog' or template contains 'collection' %}
    {% if current_page > 1 %}
      – Page {{ current_page }}
    {% endif %}
  {% endif %}
</h1>

  <div>
    {% if show_breadcrumb %}
      {% render 'breadcrumb' %}
    {% endif %}
  </div>
</div>
