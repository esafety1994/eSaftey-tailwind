{% doc %}
  @prompt
    Amend the existing Collection banner block to have two separate image uploaders — one for desktop and one for mobile. The desktop image should display on screens wider than 768px, and the mobile image should display on screens 768px and below. Both images should be configurable via the theme editor settings.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-banner-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    overflow: hidden;
    display: block;
  }

  .ai-collection-banner__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.banner_height }}px;
  }

  .ai-collection-banner__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-collection-banner__image-{{ ai_gen_id }}--desktop {
    display: block;
  }

  .ai-collection-banner__image-{{ ai_gen_id }}--mobile {
    display: none;
  }

  .ai-collection-banner__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-collection-banner__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-collection-banner__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-collection-banner__content-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    color: {{ block.settings.text_color }};
    width: 90%;
    max-width: 800px;
  }

  .ai-collection-banner__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 700;
    margin: 0 0 16px;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
  }

  .ai-collection-banner__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    margin: 0;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.3);
  }

  @media screen and (max-width: 768px) {
    .ai-collection-banner__image-{{ ai_gen_id }}--desktop {
      display: none;
    }

    .ai-collection-banner__image-{{ ai_gen_id }}--mobile {
      display: block;
    }

    .ai-collection-banner__image-wrapper-{{ ai_gen_id }} {
      height: {{ block.settings.mobile_banner_height }}px;
    }

    .ai-collection-banner__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 }}px;
    }

    .ai-collection-banner__description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<div class="ai-collection-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-collection-banner__image-wrapper-{{ ai_gen_id }}">
    {% if block.settings.desktop_image %}
      <img
        src="{{ block.settings.desktop_image | image_url: width: 2000 }}"
        alt="{{ block.settings.desktop_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.desktop_image.width }}"
        height="{{ block.settings.desktop_image.height }}"
        class="ai-collection-banner__image-{{ ai_gen_id }} ai-collection-banner__image-{{ ai_gen_id }}--desktop"
      >
    {% else %}
      <div class="ai-collection-banner__placeholder-{{ ai_gen_id }} ai-collection-banner__image-{{ ai_gen_id }}--desktop">
        {{ 'collection-apparel-1' | placeholder_svg_tag }}
        <div class="ai-collection-banner__empty-state-{{ ai_gen_id }}">
          Add a desktop image
        </div>
      </div>
    {% endif %}

    {% if block.settings.mobile_image %}
      <img
        src="{{ block.settings.mobile_image | image_url: width: 1000 }}"
        alt="{{ block.settings.mobile_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.mobile_image.width }}"
        height="{{ block.settings.mobile_image.height }}"
        class="ai-collection-banner__image-{{ ai_gen_id }} ai-collection-banner__image-{{ ai_gen_id }}--mobile"
      >
    {% else %}
      <div class="ai-collection-banner__placeholder-{{ ai_gen_id }} ai-collection-banner__image-{{ ai_gen_id }}--mobile">
        {{ 'collection-apparel-1' | placeholder_svg_tag }}
        <div class="ai-collection-banner__empty-state-{{ ai_gen_id }}">
          Add a mobile image
        </div>
      </div>
    {% endif %}

    {% if block.settings.show_overlay %}
      <div
        class="ai-collection-banner__overlay-{{ ai_gen_id }}"
        style="
          position: absolute;
          top: 0;
          left: 0;
          width: 100%;
          height: 100%;
          background-color: {{ block.settings.overlay_color }};
          opacity: {{ block.settings.overlay_opacity }};
        "
      ></div>
    {% endif %}

    {% if block.settings.title != blank or block.settings.description != blank %}
      <div class="ai-collection-banner__content-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h1 class="ai-collection-banner__title-{{ ai_gen_id }}">
            {{ block.settings.title }}
          </h1>
        {% endif %}
        {% if block.settings.description != blank %}
          <div class="ai-collection-banner__description-{{ ai_gen_id }}">
            {{ block.settings.description }}
          </div>
        {% endif %}
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Collection banner",
  "settings": [
    {
      "type": "header",
      "content": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image",
      "info": "Displays on screens wider than 768px"
    },
    {
      "type": "range",
      "id": "banner_height",
      "label": "Desktop height",
      "min": 200,
      "max": 800,
      "step": 50,
      "unit": "px",
      "default": 500
    },
    {
      "type": "header",
      "content": "Mobile image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image",
      "info": "Displays on screens 768px and below"
    },
    {
      "type": "range",
      "id": "mobile_banner_height",
      "label": "Mobile height",
      "min": 200,
      "max": 600,
      "step": 50,
      "unit": "px",
      "default": 350
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Collection name"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Discover our latest collection"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "description_size",
      "label": "Description size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "Show overlay",
      "default": true
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.3
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Collection banner"
    }
  ]
}
{% endschema %}
