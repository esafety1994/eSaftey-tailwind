{% doc %}
  @prompt
    add a banner like image strip
    
    in the collection page, make sure it fits correctly and  is recponsive 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-banner-strip-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    margin: {{ block.settings.margin_top }}px 0 {{ block.settings.margin_bottom }}px;
  }

  .ai-banner-strip-container-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 {{ block.settings.padding_horizontal }}px;
  }

  .ai-banner-strip-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-banner-strip-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .ai-banner-strip-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.aspect_ratio }};
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-banner-strip-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-banner-strip-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-banner-strip-container-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.padding_horizontal_mobile }}px;
    }

    .ai-banner-strip-{{ ai_gen_id }} {
      margin: {{ block.settings.margin_top_mobile }}px 0 {{ block.settings.margin_bottom_mobile }}px;
    }

    .ai-banner-strip-placeholder-{{ ai_gen_id }} {
      aspect-ratio: {{ block.settings.aspect_ratio_mobile }};
    }
  }
{% endstyle %}

<banner-strip-{{ ai_gen_id }}
  class="ai-banner-strip-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-banner-strip-container-{{ ai_gen_id }}">
    <div class="ai-banner-strip-image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.image %}
        {% if block.settings.link %}
          <a href="{{ block.settings.link }}">
            <img
              src="{{ block.settings.image | image_url: width: 2000 }}"
              srcset="{{ block.settings.image | image_url: width: 600 }} 600w,
                      {{ block.settings.image | image_url: width: 1000 }} 1000w,
                      {{ block.settings.image | image_url: width: 1500 }} 1500w,
                      {{ block.settings.image | image_url: width: 2000 }} 2000w"
              sizes="(max-width: 749px) 100vw, {{ block.settings.max_width }}px"
              alt="{{ block.settings.image.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
              class="ai-banner-strip-image-{{ ai_gen_id }}"
            >
          </a>
        {% else %}
          <img
            src="{{ block.settings.image | image_url: width: 2000 }}"
            srcset="{{ block.settings.image | image_url: width: 600 }} 600w,
                    {{ block.settings.image | image_url: width: 1000 }} 1000w,
                    {{ block.settings.image | image_url: width: 1500 }} 1500w,
                    {{ block.settings.image | image_url: width: 2000 }} 2000w"
            sizes="(max-width: 749px) 100vw, {{ block.settings.max_width }}px"
            alt="{{ block.settings.image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
            class="ai-banner-strip-image-{{ ai_gen_id }}"
          >
        {% endif %}
      {% else %}
        <div class="ai-banner-strip-placeholder-{{ ai_gen_id }}">
          {{ 'collection-apparel-1' | placeholder_svg_tag }}
          <div class="ai-banner-strip-empty-state-{{ ai_gen_id }}">
            Add a banner image
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</banner-strip-{{ ai_gen_id }}>

<script>
  (function() {
    class BannerStrip{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('banner-strip-{{ ai_gen_id }}', BannerStrip{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Banner strip",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Banner image"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Desktop aspect ratio",
      "options": [
        {
          "value": "21 / 9",
          "label": "Ultra wide (21:9)"
        },
        {
          "value": "16 / 9",
          "label": "Wide (16:9)"
        },
        {
          "value": "4 / 1",
          "label": "Banner (4:1)"
        },
        {
          "value": "3 / 1",
          "label": "Strip (3:1)"
        },
        {
          "value": "5 / 1",
          "label": "Thin strip (5:1)"
        }
      ],
      "default": "4 / 1"
    },
    {
      "type": "select",
      "id": "aspect_ratio_mobile",
      "label": "Mobile aspect ratio",
      "options": [
        {
          "value": "16 / 9",
          "label": "Wide (16:9)"
        },
        {
          "value": "4 / 3",
          "label": "Standard (4:3)"
        },
        {
          "value": "3 / 2",
          "label": "Medium (3:2)"
        },
        {
          "value": "2 / 1",
          "label": "Banner (2:1)"
        }
      ],
      "default": "2 / 1"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum width",
      "min": 600,
      "max": 1600,
      "step": 100,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "max_height",
      "label": "Maximum width",
      "min": 600,
      "max": 1600,
      "step": 100,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Desktop horizontal padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_horizontal_mobile",
      "label": "Mobile horizontal padding",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Desktop top margin",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Desktop bottom margin",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "margin_top_mobile",
      "label": "Mobile top margin",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "margin_bottom_mobile",
      "label": "Mobile bottom margin",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 15
    }
  ],
  "presets": [
    {
      "name": "Banner strip"
    }
  ]
}
{% endschema %}
