{% doc %}
  @prompt
    add a banner with max height and max width option
    
    smallest banner on the collection page
    
    make sure this is responsive 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-banner-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-banner-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    max-height: {{ block.settings.max_height }}px;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-banner-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    max-height: {{ block.settings.max_height }}px;
    object-fit: cover;
    display: block;
  }

  .ai-banner-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.max_height }}px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-banner-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-banner-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-banner-content-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    color: {{ block.settings.text_color }};
    width: 90%;
    max-width: 600px;
  }

  .ai-banner-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 700;
    margin: 0 0 12px;
    line-height: 1.2;
  }

  .ai-banner-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    margin: 0 0 20px;
    line-height: 1.4;
  }

  .ai-banner-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 24px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    transition: background-color 0.3s ease;
  }

  .ai-banner-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-banner-container-{{ ai_gen_id }} {
      max-height: {{ block.settings.max_height_mobile }}px;
    }

    .ai-banner-image-{{ ai_gen_id }} {
      max-height: {{ block.settings.max_height_mobile }}px;
    }

    .ai-banner-placeholder-{{ ai_gen_id }} {
      height: {{ block.settings.max_height_mobile }}px;
    }

    .ai-banner-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.7);
    }

    .ai-banner-subheading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subheading_size }}px * 0.8);
    }

    .ai-banner-button-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.button_font_size }}px * 0.9);
      padding: 10px 20px;
    }
  }
{% endstyle %}

<div class="ai-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-banner-container-{{ ai_gen_id }}">
    {% if block.settings.banner_image %}
      {% if block.settings.banner_link != blank %}
        <a href="{{ block.settings.banner_link }}">
          <img
            src="{{ block.settings.banner_image | image_url: width: 2000 }}"
            alt="{{ block.settings.banner_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.banner_image.width }}"
            height="{{ block.settings.banner_image.height }}"
            class="ai-banner-image-{{ ai_gen_id }}"
          >
        </a>
      {% else %}
        <img
          src="{{ block.settings.banner_image | image_url: width: 2000 }}"
          alt="{{ block.settings.banner_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.banner_image.width }}"
          height="{{ block.settings.banner_image.height }}"
          class="ai-banner-image-{{ ai_gen_id }}"
        >
      {% endif %}
    {% else %}
      <div class="ai-banner-placeholder-{{ ai_gen_id }}">
        {{ 'collection-apparel-1' | placeholder_svg_tag }}
        <div class="ai-banner-empty-state-{{ ai_gen_id }}">
          Add a banner image
        </div>
      </div>
    {% endif %}

    {% if block.settings.show_overlay_content %}
      <div class="ai-banner-content-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-banner-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subheading != blank %}
          <p class="ai-banner-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
        {% endif %}
        {% if block.settings.button_text != blank and block.settings.button_link != blank %}
          <a href="{{ block.settings.button_link }}" class="ai-banner-button-{{ ai_gen_id }}">
            {{ block.settings.button_text }}
          </a>
        {% endif %}
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Collection banner",
  "settings": [
    {
      "type": "header",
      "content": "Banner image"
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Image"
    },
    {
      "type": "url",
      "id": "banner_link",
      "label": "Banner link"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum width",
      "min": 400,
      "max": 2000,
      "step": 100,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "max_height",
      "label": "Maximum height (desktop)",
      "min": 100,
      "max": 800,
      "step": 50,
      "unit": "px",
      "default": 300
    },
    {
      "type": "range",
      "id": "max_height_mobile",
      "label": "Maximum height (mobile)",
      "min": 100,
      "max": 600,
      "step": 50,
      "unit": "px",
      "default": 200
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Overlay content"
    },
    {
      "type": "checkbox",
      "id": "show_overlay_content",
      "label": "Show overlay content",
      "default": false
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Subheading size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "button_font_size",
      "label": "Button font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_hover_bg_color",
      "label": "Button hover background",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Button border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Collection banner"
    }
  ]
}
{% endschema %}
