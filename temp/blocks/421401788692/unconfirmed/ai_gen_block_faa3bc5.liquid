{% doc %}
  @prompt
    create a banner with max width and max height option in layout 
    I want overlay to be hidden
    Make sure it is responsive and also the banner is only for desktop not mobile. 
    
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-desktop-banner-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    position: relative;
  }

  .ai-desktop-banner-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    max-height: {{ block.settings.max_height }}px;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
  }

  .ai-desktop-banner-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-desktop-banner-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.max_height }}px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-desktop-banner-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-desktop-banner-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-desktop-banner-{{ ai_gen_id }} {
      display: none;
    }
  }
{% endstyle %}

<div class="ai-desktop-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-desktop-banner-container-{{ ai_gen_id }}">
    {% if block.settings.banner_image %}
      {% if block.settings.banner_link != blank %}
        <a href="{{ block.settings.banner_link }}">
          <img
            src="{{ block.settings.banner_image | image_url: width: 2000 }}"
            alt="{{ block.settings.banner_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.banner_image.width }}"
            height="{{ block.settings.banner_image.height }}"
            class="ai-desktop-banner-image-{{ ai_gen_id }}"
          >
        </a>
      {% else %}
        <img
          src="{{ block.settings.banner_image | image_url: width: 2000 }}"
          alt="{{ block.settings.banner_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.banner_image.width }}"
          height="{{ block.settings.banner_image.height }}"
          class="ai-desktop-banner-image-{{ ai_gen_id }}"
        >
      {% endif %}
    {% else %}
      <div class="ai-desktop-banner-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
        <div class="ai-desktop-banner-empty-state-{{ ai_gen_id }}">
          Add a banner image
        </div>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Desktop banner",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner image"
    },
    {
      "type": "url",
      "id": "banner_link",
      "label": "Banner link"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width",
      "min": 600,
      "max": 2000,
      "step": 100,
      "unit": "px",
      "default": 1400
    },
    {
      "type": "range",
      "id": "max_height",
      "label": "Max height",
      "min": 200,
      "max": 1000,
      "step": 50,
      "unit": "px",
      "default": 500
    }
  ],
  "presets": [
    {
      "name": "Desktop banner"
    }
  ]
}
{% endschema %}
